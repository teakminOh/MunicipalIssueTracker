@inherits LayoutComponentBase
@inject IJSRuntime JS

<RadzenLayout>
    <RadzenHeader>
        <div class="app-header-content">
            <AuthorizeView>
                <RadzenSidebarToggle Click="@(() => _sidebarExpanded = !_sidebarExpanded)" />
            </AuthorizeView>
            <RadzenLabel Text="Municipal Issue Tracker" class="rz-color-white rz-ml-4 app-title" Style="font-size:1.2rem;font-weight:600;" />
            <div class="app-header-user">
                <AuthorizeView>
                    <Authorized>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8">
                            <RadzenLabel Text="@context.User.Identity?.Name" class="rz-color-white" />
                            <RadzenBadge Text="@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value" BadgeStyle="BadgeStyle.Info" />
                            <form method="post" action="/api/auth/logout">
                                <AntiforgeryToken />
                                <button type="submit" class="rz-button rz-button-sm rz-variant-outlined rz-light rz-shade-default"
                                        style="color:white; border:1px solid rgba(255,255,255,.5); padding:4px 12px; border-radius:4px; font-size:0.85rem; cursor:pointer; background:transparent;">
                                    Logout
                                </button>
                            </form>
                        </RadzenStack>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="rz-color-white">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </RadzenHeader>
    <AuthorizeView>
        <Authorized Context="authSidebar">
            <RadzenSidebar @bind-Expanded="@_sidebarExpanded" ResponsiveBreakpoint="768" Style="transition: all 0.2s ease;">
                <RadzenPanelMenu>
                    <AuthorizeView Roles="Operator,Admin">
                        <RadzenPanelMenuItem Text="Dashboard" Path="/" Icon="dashboard" />
                    </AuthorizeView>
                    <AuthorizeView Roles="Citizen">
                        <RadzenPanelMenuItem Text="My Issues" Path="/issues" Icon="list" />
                        <RadzenPanelMenuItem Text="Submit Issue" Path="/issues/create" Icon="add_circle" />
                    </AuthorizeView>
                    <AuthorizeView Roles="Operator,Admin">
                        <RadzenPanelMenuItem Text="Issues" Path="/issues" Icon="list" />
                        <RadzenPanelMenuItem Text="Map" Path="/map" Icon="map" />
                        <RadzenPanelMenuItem Text="Reports" Path="/reports" Icon="bar_chart" />
                    </AuthorizeView>
                </RadzenPanelMenu>
            </RadzenSidebar>
        </Authorized>
    </AuthorizeView>
    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

<RadzenOverlays />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _sidebarExpanded = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var width = await JS.InvokeAsync<int>("eval", "window.innerWidth");
                if (width <= 768)
                {
                    _sidebarExpanded = false;
                    StateHasChanged();
                }
            }
            catch { }
        }
    }
}
