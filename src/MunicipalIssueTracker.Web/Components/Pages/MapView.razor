@page "/map"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IssueService IssueService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Map - Municipal Issue Tracker</PageTitle>

<h3 class="rz-mb-4">Issue Map</h3>

<RadzenStack Orientation="Orientation.Horizontal" Gap="8" class="rz-mb-3" Wrap="FlexWrap.Wrap">
    <RadzenDropDown @bind-Value="_filterStatusId" Data="@_statuses" TextProperty="Name" ValueProperty="StatusId"
                    Placeholder="All Statuses" AllowClear="true" Change="@(async _ => await LoadAndRenderMarkers())" Style="width:180px;" />
    <RadzenDropDown @bind-Value="_filterCategoryId" Data="@_categories" TextProperty="Name" ValueProperty="CategoryId"
                    Placeholder="All Categories" AllowClear="true" Change="@(async _ => await LoadAndRenderMarkers())" Style="width:180px;" />
</RadzenStack>

<div id="issues-map" style="height:600px; width:100%; border-radius:var(--rz-border-radius); border:1px solid var(--rz-base-300);"></div>

@code {
    private List<Status> _statuses = new();
    private List<Category> _categories = new();
    private int? _filterStatusId;
    private int? _filterCategoryId;
    private bool _mapInitialized;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        _statuses = await IssueService.GetStatusesAsync();
        _categories = await IssueService.GetCategoriesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_disposed)
        {
            try
            {
                await JS.InvokeVoidAsync("mapInterop.initMap", "issues-map", 49.41, 19.48, 14);
                _mapInitialized = true;
                await LoadAndRenderMarkers();
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        }
    }

    private async Task LoadAndRenderMarkers()
    {
        if (!_mapInitialized || _disposed) return;

        var issues = await IssueService.GetIssuesAsync(_filterStatusId, _filterCategoryId);
        var markers = issues.Select(i => new Dictionary<string, object?>
        {
            ["id"] = i.IssueId,
            ["lat"] = i.Lat,
            ["lng"] = i.Lng,
            ["title"] = i.Title,
            ["category"] = i.Category?.Name ?? "",
            ["status"] = i.Status?.Name ?? "",
            ["priority"] = i.Priority.ToString()
        }).ToArray();

        try
        {
            await JS.InvokeVoidAsync("mapInterop.setMarkers", (object)markers);
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        try { await JS.InvokeVoidAsync("mapInterop.disposeMap"); }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }
}
