@page "/login"
@attribute [AllowAnonymous]
@layout MunicipalIssueTracker.Web.Components.Layout.MainLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject NotificationService Notification
@inject IJSRuntime JS

<PageTitle>Login - Municipal Issue Tracker</PageTitle>

<div style="display:flex; justify-content:center; align-items:center; min-height:60vh; padding:16px;">
    <RadzenCard class="login-card" Style="width:400px; max-width:100%;">
        <h4 class="rz-mb-4">Login</h4>
        <RadzenTemplateForm TItem="LoginModel" Data="@_model" Submit="@OnLogin">
            <RadzenStack Gap="16">
                <RadzenFormField Text="Email">
                    <RadzenTextBox @bind-Value="_model.Email" Style="width:100%;" />
                </RadzenFormField>
                <RadzenFormField Text="Password">
                    <RadzenPassword @bind-Value="_model.Password" Style="width:100%;" />
                </RadzenFormField>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small">
                        @_error
                    </RadzenAlert>
                }

                <RadzenButton ButtonType="ButtonType.Submit" Text="Login" Style="width:100%;" IsBusy="@_loading" />
            </RadzenStack>
        </RadzenTemplateForm>

        <hr />
        <h6>Demo Accounts</h6>
        <div class="rz-text-body2">
            <p><strong>Admin:</strong> admin@namestovo.sk / Admin123!</p>
            <p><strong>Operator:</strong> jan.kovac@namestovo.sk / Operator123!</p>
            <p><strong>Citizen:</strong> anna.kucerova@namestovo.sk / Citizen123!</p>
        </div>
    </RadzenCard>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task OnLogin()
    {
        _loading = true;
        _error = null;

        try
        {
            // Use JS fetch so the browser receives the Set-Cookie header directly
            var role = await JS.InvokeAsync<string?>("loginInterop.login", _model.Email, _model.Password);

            if (role != null)
            {
                var target = role == "Citizen" ? "/issues" : "/";
                Nav.NavigateTo(target, forceLoad: true);
            }
            else
            {
                _error = "Invalid email or password.";
            }
        }
        catch
        {
            _error = "Login failed. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
